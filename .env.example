# Copia a .env.local y rellena. Next carga .env.local automáticamente (gitignored).

# Firma de los JWT (genera: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))")
JWT_SECRET=cambia-esto
JWT_EXPIRES_IN=2h

# Admin inicial (se siembra si la tabla users está vacía; la contraseña se hashea)
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD=elige-una-contrasena-fuerte

# Pagos: 'mock' = pasarela simulada (dev). En prod: 'wompi', 'mercadopago'…
PAYMENT_PROVIDER=mock
PAYMENT_WEBHOOK_SECRET=cambia-esto-tambien

# PostgreSQL (local o gestionado: Neon, Supabase, Vercel Postgres…)
DATABASE_URL=postgresql://usuario:clave@localhost:5432/vallum
