# ──────────────────────────────────────────────────────────────────────────────
# Celestial Boutique M&V — Variables de entorno para el Orquestador
# Copia este archivo como .env en la raíz de /scripts y completa los valores
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL (Neon, Supabase, Railway, o local)
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# Anthropic (para extracción por visión desde el PDF)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Next.js — URL del endpoint de revalidación
# En desarrollo:  http://localhost:3000/api/revalidate
# En producción:  https://tudominio.com/api/revalidate
NEXT_REVALIDATE_URL=http://localhost:3000/api/revalidate

# Token secreto que protege el endpoint de revalidación
# Debe coincidir con NEXT_REVALIDATE_SECRET en el .env de Next.js
NEXT_REVALIDATE_SECRET=mi_secret_seguro_aqui

# Ruta al PDF del catálogo (relativa al directorio /scripts)
CATALOG_PDF_PATH=../CATÁLOGO PERFUMGLASS_2026.pdf
